<!DOCTYPE html> 
<html lang="en"> 
<head> 
<meta charset="UTF-8"> 
<meta name="viewport" content="width=device-width,initial-scale=1.0"> 
<title>SwiftHaul – Transport & Shipping</title> 
<link 
href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;
500&display=swap" rel="stylesheet"> 
<style> 
:root{--bg:#0a0e1a;--s1:#111827;--s2:#1a2235;--ac:#f97316;--bl:#3b82f6;--gr:#22c55e;--rd:#ef4444;--tx:#f1f5f9;--mu:#94a3b8;--br:rgba(255,255,255,0.08);--fh:'Syne',sans-serif;--fb:'DM Sans',sans
serif} 
*{margin:0;padding:0;box-sizing:border-box} 
body{background:var(--bg);color:var(--tx);font-family:var(--fb);font-size:15px;line-height:1.6;min
height:100vh} 
nav{position:fixed;top:0;width:100%;z-index:100;background:rgba(10,14,26,.93);backdrop
filter:blur(14px);border-bottom:1px solid var(--br);padding:0 2rem;height:60px;display:flex;align
items:center;justify-content:space-between} 
.logo{font-family:var(--fh);font-size:21px;font-weight:800;cursor:pointer}.logo span{color:var(--ac)} 
.nav-links{display:flex;gap:1.8rem}.nav-links a{color:var(--mu);font-size:13px;font
weight:500;cursor:pointer;transition:color .2s}.nav-links a:hover,.nav-links a.active{color:var(--tx)} 
.nav-r{display:flex;gap:8px;align-items:center} 
.btn{padding:7px 18px;border-radius:8px;font-family:var(--fb);font-size:13px;font
weight:500;cursor:pointer;transition:all .2s;border:none} 
.btn-o{background:transparent;border:1px solid var(--br);color:var(--tx)}.btn-o:hover{border
color:var(--ac);color:var(--ac)} 
.btn-p{background:var(--ac);color:#fff}.btn-p:hover{background:#fb923c;transform:translateY(
1px)} 
.page{display:none;min-height:100vh;padding-top:60px}.page.active{display:block} 
.hero{min-height:calc(100vh - 60px);display:flex;align-items:center;padding:3rem 
2rem;position:relative;overflow:hidden} 
.hbg{position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 55% 
40%,rgba(249,115,22,.1) 0%,transparent 70%),radial-gradient(ellipse 50% 50% at 15% 
80%,rgba(59,130,246,.07) 0%,transparent 60%);pointer-events:none} 
.hgrid{position:absolute;inset:0;background-image:linear-gradient(var(--br) 1px,transparent 
1px),linear-gradient(90deg,var(--br) 1px,transparent 1px);background-size:55px 55px;pointer
events:none} 
.htag{display:inline-flex;align-items:center;gap:7px;background:rgba(249,115,22,.1);border:1px solid 
rgba(249,115,22,.3);padding:5px 13px;border-radius:100px;font-size:11px;color:var(--ac);font
weight:700;letter-spacing:.05em;text-transform:uppercase;margin-bottom:1.2rem} 
.htag::before{content:'';width:6px;height:6px;background:var(--ac);border
radius:50%;animation:pulse 2s infinite} 
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}} 
h1{font-family:var(--fh);font-size:clamp(2.2rem,4.5vw,3.6rem);font-weight:800;line
height:1.1;margin-bottom:1rem} 
h1 em{font-style:normal;color:var(--ac)} 
.hero p{color:var(--mu);font-size:16px;margin-bottom:1.8rem;max-width:480px} 
.hctas{display:flex;gap:10px;flex-wrap:wrap} 
.hstats{display:flex;gap:2.5rem;margin-top:2.5rem} 
.snum{font-family:var(--fh);font-size:1.9rem;font-weight:800}.slbl{font-size:12px;color:var(--mu)} 
.sec{padding:4rem 2rem;max-width:1160px;margin:0 auto} 
.stitle{font-family:var(--fh);font-size:2rem;font-weight:700;margin-bottom:.6rem} 
.ssub{color:var(--mu);font-size:15px;margin-bottom:2.5rem;max-width:480px} 
.grid3{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.2rem} 
.card{background:var(--s1);border:1px solid var(--br);border
radius:14px;padding:1.5rem;transition:all .3s} 
.card:hover{border-color:var(--ac);transform:translateY(-3px);background:var(--s2)} 
.cicon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify
content:center;font-size:20px;margin-bottom:.9rem} 
.card h3{font-family:var(--fh);font-size:1rem;font-weight:700;margin-bottom:.4rem} 
.card p{color:var(--mu);font-size:13px} 
.cprice{margin-top:.8rem;font-size:1.3rem;font-weight:700;font-family:var(--fh);color:var(--ac)} 
.cprice small{font-size:11px;color:var(--mu);font-family:var(--fb);font-weight:400} 
.fbox{background:var(--s1);border:1px solid var(--br);border-radius:14px;padding:1.75rem;margin
bottom:1.5rem} 
.fg{margin-bottom:1.1rem}label{font-size:12px;color:var(--mu);display:block;margin
bottom:5px;font-weight:500} 
input,select,textarea{background:var(--s2);border:1px solid var(--br);color:var(--tx);padding:9px 
13px;border-radius:9px;font-family:var(--fb);font
size:14px;width:100%;outline:none;transition:border-color .2s} 
input:focus,select:focus,textarea:focus{border-color:var(--ac)} 
select option{background:var(--s1)} 
.row2{display:grid;grid-template-columns:1fr 1fr;gap:12px} 
.badge{display:inline-block;padding:3px 10px;border-radius:100px;font-size:11px;font-weight:600} 
.bg{background:rgba(34,197,94,.15);color:var(--gr)}.bo{background:rgba(249,115,22,.15);color:var(--ac)}.bb{background:rgba(59,130,246,.15);color:var(--bl)} 
.mapbox{background:var(--s2);border
radius:11px;height:300px;position:relative;overflow:hidden;border:1px solid var(--br);margin
top:1.2rem} 
.mgrid{position:absolute;inset:0;background-image:linear-gradient(rgba(59,130,246,.04) 
1px,transparent 1px),linear-gradient(90deg,rgba(59,130,246,.04) 1px,transparent 1px);background
size:38px 38px} 
.road-h{position:absolute;background:rgba(255,255,255,.06);height:12px;left:0;right:0;border
radius:3px} 
.road-v{position:absolute;background:rgba(255,255,255,.06);width:10px;top:0;bottom:0;border
radius:3px} 
.tdot{position:absolute;width:18px;height:18px;border-radius:50%;background:var(--ac);border:3px 
solid #fff;animation:rip 1.5s infinite;transition:left .8s ease,top .8s ease;z-index:5} 
@keyframes rip{0%{box-shadow:0 0 0 0 rgba(249,115,22,.5)}100%{box-shadow:0 0 0 14px 
rgba(249,115,22,0)}} 
.ddot{position:absolute;width:14px;height:14px;border-radius:50%;background:var(--gr);border:3px 
solid #fff;z-index:5} 
.mlbl{position:absolute;background:rgba(10,14,26,.9);border:1px solid var(--br);padding:3px 
9px;border-radius:5px;font-size:10px;z-index:6;white-space:nowrap} 
.tinfo{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.8rem;margin
top:1.2rem} 
.tstat{background:var(--s2);border-radius:9px;padding:.9rem;border:1px solid var(--br)} 
.tsv{font-family:var(--fh);font-size:1.2rem;font-weight:700}.tsl{font-size:11px;color:var(-
mu);margin-top:2px} 
.rtbl{width:100%;border-collapse:collapse} 
.rtbl th{text-align:left;padding:11px 14px;font-size:12px;color:var(--mu);border-bottom:1px solid 
var(--br);font-weight:500} 
.rtbl td{padding:12px 14px;border-bottom:1px solid var(--br);font-size:13px} 
.rtbl tr:hover td{background:var(--s2)} 
.awrap{min-height:calc(100vh - 60px);display:flex;align-items:center;justify
content:center;padding:2rem} 
.acard{background:var(--s1);border:1px solid var(--br);border
radius:18px;padding:2.2rem;width:100%;max-width:400px} 
.acard h2{font-family:var(--fh);font-size:1.7rem;font-weight:700;margin-bottom:.4rem} 
.acard .sub{color:var(--mu);margin-bottom:1.8rem;font-size:13px} 
.divider{display:flex;align-items:center;gap:10px;margin:1rem 0} 
.divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--br)} 
.divider span{font-size:11px;color:var(--mu)} 
.aswitch{text-align:center;margin-top:1.2rem;font-size:13px;color:var(--mu)} 
.aswitch a{color:var(--ac);cursor:pointer} 
.errmsg{background:rgba(239,68,68,.1);border:1px solid 
rgba(239,68,68,.3);color:#f87171;padding:9px 13px;border-radius:7px;font-size:13px;margin
bottom:.9rem;display:none} 
.sucmsg{background:rgba(34,197,94,.1);border:1px solid 
rgba(34,197,94,.3);color:#4ade80;padding:9px 13px;border-radius:7px;font-size:13px;margin
bottom:.9rem;display:none} 
.dgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:1rem;margin
bottom:1.8rem} 
.dc{background:var(--s1);border:1px solid var(--br);border-radius:12px;padding:1.1rem} 
.dc h4{font-size:11px;color:var(--mu);text-transform:uppercase;letter-spacing:.05em;margin
bottom:6px} 
.dc .big{font-family:var(--fh);font-size:1.9rem;font-weight:800} 
.slist{background:var(--s1);border:1px solid var(--br);border-radius:12px;overflow:hidden} 
.srow{display:grid;grid-template-columns:110px 1fr 1fr 90px 90px;gap:.8rem;padding:12px 
1.1rem;border-bottom:1px solid var(--br);align-items:center;font-size:13px} 
.srow:last-child{border-bottom:none} 
.srow.hdr{background:var(--s2);font-size:11px;color:var(--mu);font-weight:600;text
transform:uppercase;letter-spacing:.04em} 
.tgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.2rem} 
.tcard{background:var(--s1);border:1px solid var(--br);border-radius:14px;padding:1.4rem;text
align:center} 
.tav{width:66px;height:66px;border-radius:50%;margin:0 auto .9rem;display:flex;align
items:center;justify-content:center;font-size:26px} 
.tcard h4{font-family:var(--fh);font-weight:700;margin-bottom:3px}.tcard p{color:var(--mu);font
size:13px} 
.timeline{position:relative;padding-left:1.8rem} 
.timeline::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:var(--br)} 
.ti{position:relative;margin-bottom:1.8rem} 
.ti::before{content:'';position:absolute;left:-2.4rem;top:4px;width:11px;height:11px;border
radius:50%;background:var(--ac);border:2px solid var(--bg)} 
.tiy{font-size:11px;color:var(--ac);font-weight:600;margin-bottom:3px} 
.ti h4{font-family:var(--fh);font-weight:700;margin-bottom:3px}.ti p{color:var(--mu);font-size:13px} 
.cgrid{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem} 
.citem{display:flex;gap:.9rem;margin-bottom:1.3rem;align-items:flex-start} 
.cion{width:42px;height:42px;border-radius:9px;background:rgba(249,115,22,.1);border:1px solid 
rgba(249,115,22,.2);display:flex;align-items:center;justify-content:center;font-size:17px;flex
shrink:0} 
.citem h4{font-weight:600;margin-bottom:3px;font-size:14px}.citem p{color:var(--mu);font
size:13px} 
.modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:200;align
items:center;justify-content:center} 
.modal.open{display:flex} 
.mbox{background:var(--s1);border:1px solid var(--br);border
radius:18px;padding:1.8rem;width:90%;max-width:460px;max-height:90vh;overflow-y:auto} 
.toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--s1);border:1px solid var(-
br);border-radius:11px;padding:.9rem 1.1rem;z-index:9999;font-size:13px;max-width:300px;box
shadow:0 8px 28px rgba(0,0,0,.4);transform:translateY(80px);opacity:0;transition:all .3s} 
.toast.show{transform:translateY(0);opacity:1} 
footer{background:var(--s1);border-top:1px solid var(--br);padding:2.5rem 2rem} 
.fgrid{max-width:1160px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 
1fr;gap:1.8rem} 
.fb p{color:var(--mu);font-size:13px;margin-top:.6rem;max-width:260px} 
.fc h5{font-family:var(--fh);font-weight:700;margin-bottom:.9rem;font-size:13px} 
.fc a{display:block;color:var(--mu);text-decoration:none;font-size:13px;margin
bottom:7px;cursor:pointer} 
.fc a:hover{color:var(--ac)} 
.fbot{max-width:1160px;margin:1.5rem auto 0;padding-top:1.2rem;border-top:1px solid var(-
br);display:flex;justify-content:space-between;font-size:12px;color:var(--mu);flex
wrap:wrap;gap:.5rem} 
@media(max-width:768px){.nav-links{display:none}.cgrid,.row2{grid-template
columns:1fr}.fgrid{grid-template-columns:1fr 1fr}.srow{grid-template-columns:1fr 1fr}} 
</style> 
</head> 
<body> 
<nav> 
<div class="logo" onclick="go('home')">Swift<span>Haul</span></div> 
<div class="nav-links"> 
<a onclick="go('home')" id="n-home" class="active">Home</a> 
<a onclick="go('track')" id="n-track">Track</a> 
<a onclick="go('rates')" id="n-rates">Rates</a> 
<a onclick="go('about')" id="n-about">About</a> 
<a onclick="go('contact')" id="n-contact">Contact</a> 
<a onclick="go('dash')" id="n-dash" style="display:none">Dashboard</a> 
</div> 
