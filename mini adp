<div id="tr-badge"></div> 
</div> 
<div class="row2" style="margin-bottom:1.2rem"> 
<div><p style="font-size:11px;color:var(--mu);margin-bottom:3px">FROM</p><p id="tr
from" style="font-weight:500"></p></div> 
<div><p style="font-size:11px;color:var(--mu);margin-bottom:3px">TO</p><p id="tr-to" 
style="font-weight:500"></p></div> 
<div><p style="font-size:11px;color:var(--mu);margin-bottom:3px">DRIVER 
CONTACT</p><p id="tr-ph" style="font-weight:500;color:var(--ac)"></p></div> 
<div><p style="font-size:11px;color:var(--mu);margin-bottom:3px">VEHICLE</p><p id="tr
veh" style="font-weight:500"></p></div> 
</div> 
<p style="font-size:11px;color:var(--mu);font-weight:600;text-transform:uppercase;letter
spacing:.06em;margin-bottom:6px">Live Location</p> 
<div class="mapbox"> 
<div class="mgrid"></div> 
<div class="road-h" style="top:35%"></div><div class="road-h" style="top:62%"></div> 
<div class="road-v" style="left:24%"></div><div class="road-v" style="left:58%"></div><div 
class="road-v" style="left:80%"></div> 
<svg style="position:absolute;inset:0;width:100%;height:100%" viewBox="0 0 800 300" 
preserveAspectRatio="none"> 
<path d="M 56 105 Q 200 95 400 105 Q 560 112 744 105" stroke="#f97316" stroke
width="2" stroke-dasharray="8 4" fill="none" opacity=".7"/> 
</svg> 
<div style="position:absolute;left:5%;top:27%;width:13px;height:13px;border
