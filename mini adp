function animTruck(prog,status){ 
if(tivl){clearInterval(tivl);tivl=null;} 
var td=document.getElementById('tdot'),tl=document.getElementById('tlbl'); 
if(!td) return; 
var sl=8,el=80,p=Math.min(Math.max(prog,0),1); 
function setPos(){td.style.left=(sl+p*(el-sl))+'%';tl.style.left=(sl+p*(el-sl)+2)+'%';} 
setPos(); 
if(status==='Delivered'){td.style.background='var(--gr)';tl.textContent='   
Delivered';tl.style.color='var(--gr)';return;} 
if(status==='Pending Pickup'){td.style.background='var(--bl)';tl.textContent='       
Pickup';tl.style.color='var(--bl)';return;} 
td.style.background='var(--ac)';tl.textContent='            
Awaiting 
In Transit';tl.style.color='var(--ac)'; 
tivl=setInterval(function(){p=Math.min(p+.0015,.97);setPos();td.style.top=(25+(Math.random()
.5))+'%';},600); 
} 
function calcRate(){ 
var tp=document.getElementById('c-type').value; 
var wt=parseFloat(document.getElementById('c-wt').value)||0; 
var km=parseFloat(document.getElementById('c-km').value)||0; 
var cost=0; 
if(tp==='road') cost=Math.max(8*km*(wt/1000),2000); 
else if(tp==='air') cost=Math.max(180*wt,500); 
else if(tp==='sea') cost=Math.max(2400*(wt/1000),15000); 
else if(tp==='expr') cost=wt<=5?45:Math.max(9*wt,200); 
else if(tp==='cold') cost=Math.max(22*km,3500); 
document.getElementById('c-res').textContent='₹'+Math.round(cost).toLocaleString('en-IN'); 
} 
